# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
dist/
build/
.uv/
uv.lock

# defringe-ai: keep the two folders, ignore their (local, runtime) contents
inputs/*
!inputs/.gitkeep
workspace/*
!workspace/.gitkeep
out/
logs/
*.tmp.png

# Frontend (Vite/React). Build output is generated into the Python package's web/dist by
# `pnpm build` — regenerated, not committed (dist/ above already ignores it).
node_modules/
frontend/*.tsbuildinfo
.vite/

# Personal / provider-local — NOT shared. The canonical, provider-agnostic guidance is
