# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
dist/
build/
.uv/
uv.lock

# Test / coverage artifacts (regenerated by pytest / vitest)
.coverage
.coverage.*
htmlcov/
.pytest_cache/
coverage/
frontend/coverage/

# defringe-ai: keep the two folders, ignore their (local, runtime) contents
inputs/*
!inputs/.gitkeep
workspace/*
!workspace/.gitkeep
# dev.sh --reset mounts COPIES of inputs/*.png here (projection overwrites its target, so
# the source art is never the mount) — pure runtime scratch, never committed.
live/
out/
logs/
*.tmp.png

# Frontend (Vite/React). Build output is generated into the Python package's web/dist by
# `pnpm build` — regenerated, not committed (dist/ above already ignores it).
node_modules/
frontend/*.tsbuildinfo
.vite/

# Personal / provider-local — NOT shared. The canonical, provider-agnostic guidance is
# HARNESS.md + harness_driver/ (committed); CLAUDE.md is my personal prefs that chain to it.
.claude/
CLAUDE.md

# OS / editor
.DS_Store
.idea/
.vscode/
